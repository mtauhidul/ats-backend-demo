# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=5000
API_VERSION=v1

# ============================================
# FIREBASE / FIRESTORE (REQUIRED)
# ============================================
# Get your Firebase project ID from: https://console.firebase.google.com
FIREBASE_PROJECT_ID=your-firebase-project-id

# Option 1: Use service account file path (recommended for production)
# Download from: Firebase Console > Project Settings > Service Accounts > Generate New Private Key
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Option 2: Use service account JSON string (alternative for deployment platforms)
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"..."}'

# Default company ID for multi-tenant setup
DEFAULT_COMPANY_ID=default-company

# ============================================
# FRONTEND URL (CORS)
# ============================================
FRONTEND_URL=http://localhost:5173
# Production: https://your-domain.com

# ============================================
# CLOUDINARY (FILE STORAGE) - REQUIRED
# ============================================
# Get credentials from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ============================================
# OPENAI (AI RESUME PARSING & SCORING) - REQUIRED
# ============================================
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_SCORING_MODEL=gpt-4o

# ============================================
# EMAIL CONFIGURATION - OUTBOUND (RESEND) - REQUIRED
# ============================================
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-api-key

# FROM EMAIL - IMPORTANT:
# Development: Use onboarding@resend.dev (always works, no verification needed)
# Production: Use your verified domain email (e.g., noreply@yourdomain.com)
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=Arista ATS

# ============================================
# EMAIL CONFIGURATION - INBOUND (IMAP)
# ============================================
# For receiving resume emails automatically
# Production - cPanel/Custom IMAP
SYSTEM_EMAIL_HOST=mail.your-domain.com
SYSTEM_EMAIL_PORT=993
SYSTEM_EMAIL_USER=resume@your-domain.com
SYSTEM_EMAIL_PASSWORD=your_email_password
SYSTEM_EMAIL_TLS=true

# Testing - Gmail IMAP (requires App Password)
# Get App Password: https://myaccount.google.com/apppasswords
# SYSTEM_EMAIL_HOST=imap.gmail.com
# SYSTEM_EMAIL_PORT=993
# SYSTEM_EMAIL_USER=your-email@gmail.com
# SYSTEM_EMAIL_PASSWORD=your_app_password
# SYSTEM_EMAIL_TLS=true

# ============================================
# EMAIL AUTOMATION
# ============================================
EMAIL_CHECK_INTERVAL=15  # minutes
EMAIL_MAX_FETCH=50       # emails per check

# ============================================
# SECURITY - REQUIRED
# ============================================
# Generate strong random strings for production
# JWT_SECRET is used for access token generation
JWT_SECRET=your_jwt_secret_change_in_production

# REFRESH_TOKEN_SECRET is used for refresh token generation
REFRESH_TOKEN_SECRET=your_refresh_token_secret_change_in_production

# Encryption key for sensitive data (must be 32 characters)
ENCRYPTION_KEY=your_32_character_encryption_key_here

# Encryption IV (must be 16 characters)
ENCRYPTION_IV=your_16_char_iv__

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW=15     # minutes
RATE_LIMIT_MAX=1000      # max requests per window

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info           # debug, info, warn, error
LOG_FILE=logs/app.log

# ============================================
# FILE UPLOAD LIMITS
# ============================================
MAX_FILE_SIZE=10485760   # 10MB in bytes
ALLOWED_FILE_TYPES=pdf,doc,docx

# ============================================
# OPTIONAL: ADOBE PDF SERVICES (PDF TEXT EXTRACTION FALLBACK)
# ============================================
# Only needed if PDFs aren't parsing well with default parser
# Get credentials from: https://developer.adobe.com/document-services/
# Free tier: 500 transactions/month, includes OCR for scanned PDFs
# ADOBE_CLIENT_ID=your_adobe_client_id
# ADOBE_CLIENT_SECRET=your_adobe_client_secret

# ============================================
# OPTIONAL: ZOOM API (VIDEO INTERVIEWS)
# ============================================
# Only needed if using Zoom integration for interviews
# Get credentials from: https://marketplace.zoom.us/
# ZOOM_ACCOUNT_ID=your_account_id
# ZOOM_CLIENT_ID=your_client_id
# ZOOM_CLIENT_SECRET=your_client_secret

# ============================================
# OPTIONAL: RESEND INBOUND EMAIL WEBHOOK
# ============================================
# Only needed if using Resend's inbound email feature
# Get webhook secret from: https://resend.com/webhooks
# RESEND_WEBHOOK_SECRET=your_webhook_secret_here
